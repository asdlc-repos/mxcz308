{"type":"assistant","message":{"model":"claude-sonnet-4-6","id":"msg_01YNVuBNGmFYjUurVbYZfMYp","type":"message","role":"assistant","content":[{"type":"tool_use","id":"toolu_018JgWiNNqxRJSWoJ4ywm7SK","name":"Write","input":{"file_path":"/Users/wso2/.asdlc/repos/default/mxcz/leave-service/internal/middleware/middleware.go","content":"package middleware\n\nimport (\n\t\"log\"\n\t\"net/http\"\n\t\"time\"\n)\n\n// responseWriter wraps http.ResponseWriter to capture the status code written.\ntype responseWriter struct {\n\thttp.ResponseWriter\n\tstatus int\n}\n\nfunc (rw *responseWriter) WriteHeader(code int) {\n\trw.status = code\n\trw.ResponseWriter.WriteHeader(code)\n}\n\n// Write satisfies http.ResponseWriter; if WriteHeader was never called explicitly,\n// Go's default is 200, so we set it here the first time.\nfunc (rw *responseWriter) Write(b []byte) (int, error) {\n\tif rw.status == 0 {\n\t\trw.status = http.StatusOK\n\t}\n\treturn rw.ResponseWriter.Write(b)\n}\n\n// Logging wraps the given handler with structured request/response logging.\n// It logs: timestamp (RFC3339), HTTP method, path, response status, and duration.\nfunc Logging(next http.Handler) http.Handler {\n\treturn http.HandlerFunc(func(w http.ResponseWriter, r *http.Request) {\n\t\tstart := time.Now()\n\t\trw := &responseWriter{ResponseWriter: w, status: 0}\n\t\tnext.ServeHTTP(rw, r)\n\t\tstatus := rw.status\n\t\tif status == 0 {\n\t\t\tstatus = http.StatusOK\n\t\t}\n\t\tlog.Printf(\"INFO %s method=%s path=%q status=%d duration=%s\",\n\t\t\tstart.Format(time.RFC3339),\n\t\t\tr.Method,\n\t\t\tr.URL.Path,\n\t\t\tstatus,\n\t\t\ttime.Since(start).String(),\n\t\t)\n\t})\n}\n\n// CORS wraps the given handler with permissive CORS headers suitable for a\n// browser-based leave portal calling this backend.\nfunc CORS(next http.Handler) http.Handler {\n\treturn http.HandlerFunc(func(w http.ResponseWriter, r *http.Request) {\n\t\tw.Header().Set(\"Access-Control-Allow-Origin\", \"*\")\n\t\tw.Header().Set(\"Access-Control-Allow-Methods\", \"GET, POST, PATCH, PUT, DELETE, OPTIONS\")\n\t\tw.Header().Set(\"Access-Control-Allow-Headers\", \"Content-Type, Authorization\")\n\n\t\t// Respond immediately to pre-flight requests.\n\t\tif r.Method == http.MethodOptions {\n\t\t\tw.WriteHeader(http.StatusNoContent)\n\t\t\treturn\n\t\t}\n\n\t\tnext.ServeHTTP(w, r)\n\t})\n}\n\n// Chain applies a list of middleware functions to a handler (outermost first).\nfunc Chain(h http.Handler, middlewares ...func(http.Handler) http.Handler) http.Handler {\n\tfor i := len(middlewares) - 1; i >= 0; i-- {\n\t\th = middlewares[i](h)\n\t}\n\treturn h\n}\n"},"caller":{"type":"direct"}}],"stop_reason":null,"stop_sequence":null,"stop_details":null,"usage":{"input_tokens":1,"cache_creation_input_tokens":909,"cache_read_input_tokens":23332,"cache_creation":{"ephemeral_5m_input_tokens":909,"ephemeral_1h_input_tokens":0},"output_tokens":9,"service_tier":"standard","inference_geo":"global"},"context_management":null},"parent_tool_use_id":null,"session_id":"4f4371ae-b5cb-4282-90f7-3ba15cbb2514","uuid":"5dd4860e-6133-4ac0-a17d-adee3d4cf398"}
